<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ultimate Game Hub</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

        body {
            margin: 0;
            padding: 0;
            background: #1a0a2e;
            color: #fff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
        }

        /* Тоглоомын үндсэн дэлгэц */
        .game-wrapper {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            padding: 40px 20px;
            background: linear-gradient(to bottom, #1a0a2e 0%, #3d1a5e 100%);
        }

        .game-card {
            width: 350px;
            background: #2d1b4d;
            border: 4px solid #ffd700;
            border-radius: 15px;
            position: relative;
            box-shadow: 0 0 20px rgba(0,0,0,0.8), inset 0 0 15px rgba(255, 215, 0, 0.2);
            padding: 20px;
            transition: 0.3s;
        }

        .game-card:hover {
            transform: scale(1.02);
            box-shadow: 0 0 40px rgba(255, 215, 0, 0.4);
        }

        .card-header {
            font-family: 'Press Start 2P', cursive;
            font-size: 12px;
            color: #ffd700;
            margin-bottom: 20px;
            text-align: center;
        }

        /* 3D Баатрын хэсэг */
        .character-zone {
            height: 150px;
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0,0,0,0.3);
            border-radius: 10px;
            margin-bottom: 15px;
            position: relative;
        }

        .game-img {
            width: 100px;
            height: 100px;
            object-fit: contain;
            filter: drop-shadow(0 0 10px rgba(255,255,255,0.5));
            animation: bounce 2s infinite ease-in-out;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        /* Товчлуурууд */
        .btn-play {
            width: 100%;
            background: linear-gradient(#ffcc00, #ff9900);
            border: none;
            border-bottom: 4px solid #cc7a00;
            padding: 12px;
            font-weight: bold;
            color: #2d1b4d;
            border-radius: 8px;
            cursor: pointer;
            text-transform: uppercase;
            margin-top: 10px;
        }

        .btn-play:active {
            transform: translateY(2px);
            border-bottom: none;
        }

        input {
            width: calc(100% - 24px);
            padding: 10px;
            background: #1a0a2e;
            border: 2px solid #5d3b8e;
            color: #ffd700;
            border-radius: 5px;
            margin: 10px 0;
            text-align: center;
        }

        .stat-bar {
            background: #444;
            height: 10px;
            border-radius: 5px;
            margin: 10px 0;
            overflow: hidden;
        }

        .stat-fill {
            background: #00ff00;
            height: 100%;
            width: 100%;
            transition: 0.5s;
        }

        #resultText {
            font-family: 'Press Start 2P', cursive;
            font-size: 10px;
            color: #ff3e3e;
            height: 20px;
        }

    </style>
</head>
<body>

    <div style="text-align:center; padding-top:20px;">
        <h1 style="font-family: 'Press Start 2P'; font-size: 24px; color: #ffd700;">HERO'S QUEST</h1>
    </div>

    <div class="game-wrapper">

        <div class="game-card">
            <div class="card-header">BOSS LEVEL: 99</div>
            <div class="character-zone">
                <img id="bossImg" src="boss.png" alt="BOSS" class="game-img">
            </div>
            <div class="stat-bar"><div id="hpBar" class="stat-fill"></div></div>
            <p style="text-align: center; font-size: 12px;">Боссын нууц кодыг таа!</p>
            <center><h2 id="numView" style="color: #00ffcc; height: 30px;"></h2></center>
            <button class="btn-play" onclick="bossSpawn()">Код харах</button>
            <input type="number" id="guessInput" placeholder="НУУЦ КОД">
            <button class="btn-play" style="background: #ff3e3e; color: white; border-bottom: 4px solid #b31e1e;" onclick="attackBoss()">ATTACK!</button>
        </div>

        <div class="game-card">
            <div class="card-header">LOOT CHEST</div>
            <div class="character-zone">
                <img id="diceImg" src="chest.webp
                " alt="CHEST" class="game-img">
            </div>
            <h1 id="totalGold" style="text-align:center; color: #ffd700;">💰 0</h1>
            <p style="text-align: center; font-size: 12px;">6 удаа орхиж алт цуглуул!</p>
            <button id="rollBtn" class="btn-play" onclick="rollLoot()">ОРХИХ</button>
        </div>

        <div class="game-card">
            <div class="card-header">ARENA BATTLE</div>
            <div class="character-zone">
                <img id="enemyImg" src="enemy.png" alt="ENEMY" class="game-img">
            </div>
            <div id="battleMsg" style="text-align: center; font-weight: bold; height: 30px; color: #00ffcc;">Бэлэн үү?</div>
            <div style="display: flex; gap: 5px;">
                <button class="btn-play" style="font-size: 10px;" onclick="arena('haich')">ХАЙЧ</button>
                <button class="btn-play" style="font-size: 10px;" onclick="arena('chuluu')">ЧУЛУУ</button>
                <button class="btn-play" style="font-size: 10px;" onclick="arena('daavuu')">ДААВУУ</button>
            </div>
        </div>

    </div>

    <script>
        // --- 1. BOSS BATTLE ---
        let bossCode = 0;
        let hp = 100;
        function bossSpawn() {
            bossCode = Math.floor(Math.random() * 9000) + 1000;
            document.getElementById("numView").innerHTML = bossCode;
            setTimeout(() => { document.getElementById("numView").innerHTML = "****"; }, 200);
        }
        function attackBoss() {
            let guess = document.getElementById("guessInput").value;
            if(guess == bossCode) {
                hp -= 20;
                document.getElementById("hpBar").style.width = hp + "%";
                alert("🔥 ХҮЧТЭЙ ЦОХИЛТ! Босс 20 HP алдлаа.");
                if(hp <= 0) alert("🏆 ТА ЯЛЛАА! БОССЫГ УСТГАЛАА.");
            } else {
                alert("❌ АЛДЛАА! Босс таныг цохилоо.");
            }
            document.getElementById("guessInput").value = "";
        }

        // --- 2. LOOT CHEST ---
        let gold = Number(localStorage.getItem("gold")) || 0;
        let rolls = 0;
        document.getElementById("totalGold").innerHTML = "💰 " + gold;

        function rollLoot() {
            if(rolls < 6) {
                let r = Math.floor(Math.random() * 6) + 1;
                gold += r * 100;
                document.getElementById("diceImg").src = "shoo" + r + ".png";
                document.getElementById("totalGold").innerHTML = "💰 " + gold;
                localStorage.setItem("gold", gold);
                rolls++;
                if(rolls == 6) {
                    document.getElementById("rollBtn").disabled = true;
                    document.getElementById("rollBtn").innerHTML = "ХОЁСОН";
                }
            }
        }

        // --- 3. ARENA ---
        function arena(user) {
            const monster = ['haich', 'chuluu', 'daavuu'];
            const ai = monster[Math.floor(Math.random() * 3)];
            document.getElementById("enemyImg").src = ai + ".png";
            
            let result = "";
            if(user === ai) result = "ТЭНЦЛЭЭ! 🛡️";
            else if((user==='chuluu' && ai==='haich') || (user==='haich' && ai==='daavuu') || (user==='daavuu' && ai==='chuluu')) {
                result = "ЯЛАЛТ! ⚔️";
            } else {
                result = "ЯЛАГДЛАА... 💀";
            }
            document.getElementById("battleMsg").innerHTML = result;
        }
    </script>
</body>
</html>
